// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

/// 앱 사용자 (JK / MY 고정 2인)
model User {
  id            String         @id
  name          String
  createdAt     DateTime       @default(now())
  workplaces    Workplace[]
  accounts      Account[]
  monthlyBudgets MonthlyBudget[]
  bucketLists   BucketList[]
  subscriptions Subscription[]
}

model Account {
  id             String     @id @default(uuid())
  userId         String     @default("74881cb7-6fa0-4a86-a6b3-cf3e271c7ce0")
  user           User       @relation(fields: [userId], references: [id])
  name           String     // 계좌명
  type           String     // 입출금, 금고, 저축, 증권, 연금
  bankName       String?    // 은행/증권사 명
  accountNumber  String?    // 계좌번호
  description    String?    // 계좌 용도 설명
  initialBalance Int        @default(0) // 초기 잔액
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt
  transactions   CashFlow[] // 연결된 예산/현금흐름
  subscriptions  Subscription[]
}

model MonthlyBudget {
  id                String     @id @default(uuid())
  userId            String     @default("74881cb7-6fa0-4a86-a6b3-cf3e271c7ce0")
  user              User       @relation(fields: [userId], references: [id])
  month             String     // "YYYY-MM" 포맷
  personalAllowance Int        @default(0) // 전월 이월된 개인 용돈
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  transactions      CashFlow[]

  @@unique([userId, month])
}

model CashFlow {
  id                     String                  @id @default(uuid())
  type                   String                  // INCOME, EXPENSE_FIXED, EXPENSE_VAR, SAVING
  title                  String                  // 내역
  amount                 Int
  isCompleted            Boolean                 @default(false) // 실제 집행 여부 (체크박스)
  monthlyBudgetId        String
  monthlyBudget          MonthlyBudget           @relation(fields: [monthlyBudgetId], references: [id], onDelete: Cascade)
  accountId              String?                 // 자산과 연동될 경우 계좌 ID
  account                Account?                @relation(fields: [accountId], references: [id])
  /// 알바 근무지에서 월별 실수령으로 자동 생성된 수입일 때만 설정 (수동 수입과 구분)
  workplaceId            String?
  workplace              Workplace?              @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  createdAt              DateTime                @default(now())

  @@unique([monthlyBudgetId, workplaceId])
}

model BucketList {
  id            String   @id @default(uuid())
  userId        String   @default("74881cb7-6fa0-4a86-a6b3-cf3e271c7ce0")
  user          User     @relation(fields: [userId], references: [id])
  title         String
  importance    Int      @default(3) // 중요도
  targetAmount  Int
  currentAmount Int      @default(0)
  isAchieved    Boolean  @default(false) // 돈 목표 달성
  isCompleted   Boolean  @default(false) // 실제 완료 (물건 구매/여행 완료 등)
  completedAt   DateTime? // 사용자가 선택한 달성일 (캘린더 일자)
  imageUrl      String?  // 이미지 링크 저장
  createdAt     DateTime @default(now())
}

model SystemSettings {
  id              String   @id @default("global")
  budgetStartDate Int      @default(1) // 예산 시작일 (1~31)
  updatedAt       DateTime @updatedAt
}

model Subscription {
  id         String   @id @default(uuid())
  userId     String   @default("74881cb7-6fa0-4a86-a6b3-cf3e271c7ce0")
  user       User     @relation(fields: [userId], references: [id])
  name       String
  amount     Int
  billingDay Int      @default(1)
  category   String
  isActive   Boolean  @default(true)
  accountId  String?
  account    Account? @relation(fields: [accountId], references: [id])
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

/// 아르바이트·정규직 근무지 (사용자당 다수)
model Workplace {
  id                        String       @id @default(uuid())
  userId                    String
  user                      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                      String
  color                     String       // UI 구분용 색상 코드 (예: #RRGGBB)
  isActive                  Boolean      @default(true) // 퇴사/미사용 구분
  /// PARTTIME | FULLTIME
  type                      String       @default("PARTTIME")
  hourlyWage                Int          @default(10030) // 시급(원) — 근무 기록에 복사·동기화 (정규직은 통상시급 등으로 동기화)
  isWeeklyAllowanceActive   Boolean      @default(true) // 주휴수당 적용
  isTaxActive               Boolean      @default(true) // 3.3% 세금 적용
  /// 매월 급여 지급일 (1~31, 해당 월 말일이 더 짧으면 말일로 처리)
  paydayOfMonth             Int          @default(10)
  /// CALENDAR_MONTH: 당월 1일~말일 근무 → 익월 payday 지급 / ROLLING_BEFORE_PAYDAY: 전 월급일~이번 월급 전날 근무 → 이번 월급일 지급
  payPeriodMode             String       @default("CALENDAR_MONTH")
  /// 정규직 전용: 월 기본급(원)
  monthlyBaseSalary         Int?
  /// 정규직 전용: 수당 JSON 배열 [{ id, name, amount, isTaxExempt }]
  allowances                Json?
  /// 정규직 전용: 부양가족 수 (간이세액표, 1~11)
  taxDependents             Int?
  /// 정규직 전용: 입사일 YYYY-MM-DD
  hireDate                  String?
  /// 정규직 전용: 연간 발생 연차 일수
  annualLeaveTotal          Float?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  workRecords               WorkRecord[]
  budgetIncomeLines         CashFlow[]   // 월별 예산에 자동 반영된 실수령 수입 (근무지당 월 1건)

  @@index([userId])
}

/// 근무 기록 (근무지당 다수)
model WorkRecord {
  id                        String    @id @default(uuid())
  workplaceId               String
  workplace                 Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  date                      DateTime  // 근무일 (일자 기준 조회·주차 계산에 사용)
  /// 알바: 필수. 정규직 추가만 기록 시 null
  startTime                 DateTime?
  endTime                   DateTime?
  breakTimeMinutes          Int? // 휴게(분); 추가만 기록 시 null
  hourlyWage                Int       // 시급(원)
  isWeeklyAllowanceActive   Boolean   @default(true) // 주휴수당 적용 여부(수동)
  isTaxActive               Boolean   @default(true) // 3.3% 세금 적용 여부(수동)
  /// 정규직 전용: 연장근무 분
  overtimeMinutes           Int?
  /// 정규직 전용: 야간근무 분 (22~06)
  nightMinutes              Int?
  /// 정규직 전용: 휴일근무 분
  holidayMinutes            Int?
  /// 정규직 전용: 해당 일 상여·일시금(원)
  bonusAmount               Int?
  /// 정규직 전용: 상여 과세 여부
  isBonusTaxable            Boolean?
  /// 정규직 전용: 연차 사용 일수 (1 / 0.5 / 0.25)
  leaveUsed                 Float?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([workplaceId])
  @@index([date])
}
